<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

    <link rel="stylesheet" href="/css/styles.css">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Guia de Jogos</title>
</head>

<body>
<header> <%- include("partials/header")%></header>
<div class="game-container">

    <div class="cab-img">
        <img src="<%= resultado[0].url %>" alt="capa" width="600" height="400">
    </div>

    <div class="cab-infos">
        <h1>Titulo: <span><%= resultado[0].titulo%></span> </h1>

        <h2>Lançamento: <span><%= resultado[0].data  %></span> </h2>

        <h2>Desenvolvedora: <span><%= resultado[0].dev  %></span> </h2>

        <h2>Visite na Steam: <span><a href="<%= resultado[0].link_steam %>" target="_blank"><%= resultado[0].link_steam  %></a></span> </h2>
    </div>
</div>

    <div class="texto">
        <% for (i=0;i<resultado[0].texto.length; i++) { %>
        <p><%=resultado[0].texto[i] %></p>
        <% } %>
</div>





<footer></footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>

</html>